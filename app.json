{
  "expo": {
    "name": "WinTasks",
    "slug": "WinTasks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.diemo31.WinTasks",
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["whatsapp"],
        "NSCameraUsageDescription": "Usado para escanear códigos QR",
        "NSPhotoLibraryUsageDescription": "Usado para guardar códigos QR",
        "NSFaceIDUsageDescription": "Usado para autenticación biométrica"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E05A47",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.diemo31.WinTasks"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
